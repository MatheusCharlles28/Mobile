<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#ADB5C8" />
            <stroke android:width="2dp" android:color="#404040" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#ECE9D8" />
            <stroke android:width="2dp" android:color="#0A246A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#E0DDD0" />
            <stroke android:width="1dp" android:color="#808080" />
        </shape>
    </item>
</selector>
