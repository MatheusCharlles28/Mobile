<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradiente azul XP clássico -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1956C8"
                android:centerColor="#3A7BD5"
                android:endColor="#1040A0"
                android:angle="270" />
        </shape>
    </item>
    <!-- Linha brilhante no topo -->
    <item android:bottom="28dp">
        <shape android:shape="rectangle">
            <solid android:color="#5090E8" />
        </shape>
    </item>
</layer-list>
