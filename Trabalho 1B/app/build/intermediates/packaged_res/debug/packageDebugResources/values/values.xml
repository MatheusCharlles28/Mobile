    <color name="colorAccent">@color/accent_green</color>
    <color name="colorPrimary">@color/xp_blue_mid</color>
    <color name="colorPrimaryDark">@color/xp_blue_title</color>
    <color name="list_background">@color/background_dark</color>
    <color name="primary">@color/xp_blue_mid</color>
    <color name="primary_dark">@color/xp_blue_title</color>
    <color name="success">@color/accent_green</color>
    <color name="text_primary">#1A1000</color>
    <color name="text_secondary">#5A4A20</color>
    <color name="total_background">@color/xp_gray_face</color>
    <color name="xp_blue_light">#6B9FD4</color>
