<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item><shape android:shape="rectangle"><solid android:color="#FFF8E7"/><corners android:radius="2dp"/></shape></item>
            <item android:top="1dp" android:left="1dp">
                <shape android:shape="rectangle"><solid android:color="#1A4A1A"/><corners android:radius="1dp"/></shape>
            </item>
            <item android:top="2dp" android:left="2dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <gradient android:startColor="#2A5A2A" android:endColor="#3A7A3A" android:angle="270"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item><shape android:shape="rectangle"><solid android:color="#1A4A1A"/><corners android:radius="2dp"/></shape></item>
            <item android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle"><solid android:color="#2A6A2A"/><corners android:radius="2dp"/></shape>
            </item>
            <item android:top="1dp" android:left="1dp">
                <shape android:shape="rectangle"><solid android:color="#6AAA6A"/><corners android:radius="1dp"/></shape>
            </item>
            <item android:top="2dp" android:left="2dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <gradient android:startColor="#4A9A4A" android:endColor="#2A6A2A" android:angle="270"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
