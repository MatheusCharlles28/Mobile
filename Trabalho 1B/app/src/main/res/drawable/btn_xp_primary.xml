<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1432A0" />
            <stroke android:width="2dp" android:color="#0A1A6A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2357CC" />
            <stroke android:width="1dp" android:color="#0A246A" />
        </shape>
    </item>
</selector>
